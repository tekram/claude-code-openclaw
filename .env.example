# Path to the sessions log written by the hook script.
# Default (no env var needed) if using Option B / OpenClaw setup:
#   ~/.openclaw/workspace/sessions.log
# Required if using Option A (~/.claude-dash/) setup:
# CLAUDE_DASH_LOG_PATH=~/.claude-dash/sessions.log

# Path to notification preferences (auto-created on first save in Settings UI).
# CLAUDE_DASH_NOTIF_PREFS=~/.openclaw/workspace/claude-dash-notifications.json

# Path to OpenClaw config — only needed if using OpenClaw-based notifications.
# OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json
